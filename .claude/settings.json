{
  "autoCompactEnabled": true,
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--headed"]
    }
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -NonInteractive -File scripts/sincronizar-repos.ps1 2>&1"
          }
        ]
      }
    ],
    "Stop": []
  }
}
