# ── Supabase ──────────────────────────────────────────────────────────────────
# Obter em supabase.com → Project Settings → API
SUPABASE_URL=https://[projeto-id].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Único custo variável do sistema (~R$20-50/mês por SaaS com uso normal)
# Obter em console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Criptografia de credenciais dos workspaces ────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

# ── Autenticação do dashboard ─────────────────────────────────────────────────
APP_PASSWORD=admin

# ── Domínio público (opcional — para webhooks) ────────────────────────────────
APP_URL=https://fabrica.seudominio.com

# ── Supabase Edge Functions ───────────────────────────────────────────────────
# Configurar também no painel: Project Settings → Edge Functions → Secrets
# Os mesmos valores de ANTHROPIC_API_KEY, SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY
