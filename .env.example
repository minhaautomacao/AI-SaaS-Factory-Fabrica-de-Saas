# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# APP_PASSWORD: Site password to lock the SaaS Factory workspace for security
APP_PASSWORD="admin"

# ============================================================
# Orquestrador (orchestrator/) — ver orchestrator/.env.example
# ============================================================
# Supabase — obter em supabase.com → Settings → API
SUPABASE_URL=https://[projeto-id].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — obter em console.upstash.com → Redis → REST API
UPSTASH_REDIS_URL=rediss://default:...@...upstash.io:6379
UPSTASH_REDIS_TOKEN=

# Anthropic — obter em console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-

