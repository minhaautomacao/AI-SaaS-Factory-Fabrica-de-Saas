# Supabase — obrigatório
# Obter em: supabase.com → projeto → Settings → API
SUPABASE_URL=https://[projeto-id].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # chave service_role (NÃO usar anon_key)

# Upstash Redis — obrigatório
# Obter em: console.upstash.com → Redis → seu banco → REST API
UPSTASH_REDIS_URL=rediss://default:...@...upstash.io:6379
UPSTASH_REDIS_TOKEN=AX...

# Anthropic — obrigatório para agentes que usam Claude
# Obter em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Ambiente
NODE_ENV=development

# WhatsApp (Evolution API) — opcional, necessário para agentes de WhatsApp
# Obter ao configurar a Evolution API conforme infraestrutura/whatsapp.md
EVOLUTION_API_URL=https://evolution.seu-dominio.com
EVOLUTION_API_KEY=...
EVOLUTION_INSTANCE=floricultura

# Notificações para Carlos (número WhatsApp do operador)
CARLOS_WHATSAPP=5511999999999
