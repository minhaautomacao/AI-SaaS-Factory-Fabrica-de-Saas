# ── Supabase ───────────────────────────────────────────────────────────────
# Project Settings → API → Project URL e anon key
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe (opcional — use Mercado Pago abaixo se preferir) ───────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASICO=price_...
STRIPE_PRICE_PRO=price_...

# ── Mercado Pago (alternativa ao Stripe) ──────────────────────────────────
# https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-...

# ── Email (Resend) ────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=contato@seudominio.com.br

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://seudominio.com.br
NEXT_PUBLIC_APP_NAME=Meu SaaS
